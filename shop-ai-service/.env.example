APP_NAME=shop-ai-service
APP_ENV=local
LOG_LEVEL=INFO

# Internal shop-server endpoint. Keep model providers behind this service.
SHOP_SERVER_BASE_URL=http://127.0.0.1:48080
SHOP_SERVER_INTERNAL_TOKEN=
SHOP_SERVER_TIMEOUT_SECONDS=10
SHOP_SERVER_RETRY_ATTEMPTS=2

# OpenAI-compatible provider configuration.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=60

# Local conversation context. sqlite=single instance; redis=multi-instance.
MEMORY_BACKEND=sqlite
MEMORY_DB_PATH=data/shop-ai.db
MEMORY_MAX_MESSAGES=12
REDIS_URL=

# Local FAQ/policy knowledge (SQLite FTS). Product price/stock still use live tools.
KNOWLEDGE_DIR=knowledge
KNOWLEDGE_DB_PATH=data/shop-ai-knowledge.db
KNOWLEDGE_TOP_K=4

# Production guards
RATE_LIMIT_PER_MINUTE=30
AUDIT_DB_PATH=data/shop-ai-audit.db
ENABLE_PROMPT_GUARD=true
ENABLE_OUTPUT_REDACTION=true

# Optional vector store (not required for current local RAG).
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=shop_knowledge