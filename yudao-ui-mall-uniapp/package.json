{
  "id": "shopro",
  "name": "shopro",
  "displayName": "商城",
  "version": "2026.06",
  "description": "商城移动端，一套代码同时发行到 iOS、Android、H5、微信小程序多个平台。",
  "scripts": {
    "dev:h5": "cross-env UNI_INPUT_DIR=. uni -p h5",
    "build:h5": "cross-env UNI_INPUT_DIR=. uni build -p h5",
    "dev:mp-weixin": "cross-env UNI_INPUT_DIR=. uni -p mp-weixin",
    "build:mp-weixin": "cross-env UNI_INPUT_DIR=. uni build -p mp-weixin",
    "dev:app": "cross-env UNI_INPUT_DIR=. uni -p app",
    "build:app": "cross-env UNI_INPUT_DIR=. uni build -p app",
    "prettier": "prettier --write  \"{pages,sheep}/**/*.{js,json,tsx,css,less,scss,vue,html,md}\""
  },
  "repository": "https://github.com/sheepjs/shop.git",
  "keywords": [
    "商城",
    "B2C",
    "商城模板"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sheepjs/shop/issues"
  },
  "homepage": "https://github.com/dcloudio/hello-uniapp#readme",
