# 生产环境：只在打包时使用
NODE_ENV=production

VITE_DEV=false

# 请求路径；默认同域反代 /admin-api，跨域部署时填正式后端域名
VITE_BASE_URL=''

# 文件上传类型：server - 后端上传， client - 前端直连上传，仅支持S3服务
VITE_UPLOAD_TYPE=server

# 接口地址
VITE_API_URL=/admin-api

# 是否删除debugger
VITE_DROP_DEBUGGER=true

# 是否删除console.log
VITE_DROP_CONSOLE=true

# 是否sourcemap
VITE_SOURCEMAP=false

# 是否开启压缩，可以设置为 none, gzip, brotli, gzip,brotli
VITE_COMPRESS=none

# 打包路径
VITE_BASE_PATH=/

# 输出路径
VITE_OUT_DIR=dist-prod

# 商城H5会员端域名，店铺装修预览使用
VITE_MALL_H5_DOMAIN=''

# GoView域名；报表模块未启用时留空
VITE_GOVIEW_URL=''
